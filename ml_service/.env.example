# ── Email Configuration (Gmail) ────────────────────────────────────────────────
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here   # Use a Gmail App Password, not your account password
EMAIL_RECEIVER=police@example.com

# ── Twilio SMS (Optional) ──────────────────────────────────────────────────────
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890
ADMIN_PHONE=+1234567890

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the ML service.
# In production, set this to your backend server's actual URL.
# Default (local dev): http://localhost:4005,http://127.0.0.1:4005
ALLOWED_ORIGINS=http://localhost:4005,http://127.0.0.1:4005

# ── Flask ──────────────────────────────────────────────────────────────────────
# Set to 1 ONLY for local development. NEVER set in production.
FLASK_DEBUG=0
